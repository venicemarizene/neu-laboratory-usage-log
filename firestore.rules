
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalUser() {
      // Check for institutional domain
      return isSignedIn() && 
             'email' in request.auth.token &&
             request.auth.token.email.matches('(?i).*@([^@]+\\.)?neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Standard administrative check
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      return !exists(profilePath) || get(profilePath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      // Users can always read their own profile. Admins can read all. 
      // Institutional users can check existence of profiles for logging purposes.
      allow get: if isOwner(userId) || isAdmin() || isInstitutionalUser();
      allow list: if isAdmin() || isInstitutionalUser();
      
      // Institutional users can initialize their own profile.
      allow create: if isInstitutionalUser() && isOwner(userId);
      
      // Owners can update their details, admins have full control.
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /room_logs/{logId} {
      // Admins and staff can view logs.
      allow get, list: if isAdmin() || isInstitutionalUser();
      
      // Active institutional users can create logs.
      allow create: if isInstitutionalUser() && 
                       isNotBlocked() && 
                       request.resource.data.professorId == request.auth.uid;
                       
      allow update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      // Self-read for layout checks, admin-read for auditing.
      allow get: if isOwner(userId) || isAdmin();
      
      // Institutional users can register themselves as admin if they signed in through the admin portal.
      // In a real production app, this would be restricted further or handled by an Admin SDK.
      allow create, update: if isOwner(userId) && isInstitutionalUser();
      
      allow list: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
