
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalUser() {
      // Robust check for main domain and institutional subdomains with field existence check
      return isSignedIn() && 
             'email' in request.auth.token &&
             request.auth.token.email.matches('(?i).*@([^@]+\\.)?neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check for explicit admin role in roles_admin collection
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      // If profile doesn't exist, they are not blocked yet (initial creation)
      return !exists(profilePath) || get(profilePath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isInstitutionalUser();
      allow list: if isInstitutionalUser() || isAdmin();
      allow create: if isInstitutionalUser() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin() || isInstitutionalUser();
      allow delete: if isAdmin();
    }

    match /room_logs/{logId} {
      allow get, list: if isAdmin() || isInstitutionalUser();
      allow create: if isInstitutionalUser() && 
                       isNotBlocked() && 
                       request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isAdmin() || isInstitutionalUser();
    }

    match /roles_admin/{userId} {
      // Allow the user to check their own role status and institutional users to check existence
      allow get: if isOwner(userId) || isAdmin() || isInstitutionalUser();
      // Allow creation and update for the owner (marker for admin status)
      allow create, update: if isOwner(userId) && isInstitutionalUser();
      allow list, delete: if false;
    }
  }
}
