
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isActive(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.status == 'active';
    }

    match /users/{userId} {
      // Prototype relaxation: Allow retrieval and listing (for email queries) to support QR identification
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      // Prototype relaxation: Allow reading and creating logs to support QR-based sessions
      allow read: if true;
      allow create: if true; 
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.auth.token.email == resource.data.professorEmail
      ) || (
        // Allow updates if the email matches the payload (for QR sessions)
        request.resource.data.professorEmail == resource.data.professorEmail
      );
      allow delete: if isAdmin();
    }
  }
}
