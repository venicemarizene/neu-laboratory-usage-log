rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Lab Log Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a Role-Based Access Control (RBAC) model combined with strict user-ownership.
     * It prioritizes "Authorization Independence" by using a dedicated administration collection for 
     * role-based checks, minimizing expensive document lookups.
     *
     * DATA STRUCTURE:
     * - /user_profiles/{userId}: Store profile metadata (role, status). Root level for easy access.
     * - /room_logs/{roomLogId}: Laboratory usage records. Flat structure for administrative reporting.
     * - /roles_admin/{userId}: Marker documents for rapid administrator verification.
     *
     * KEY SECURITY DECISIONS:
     * - NEU Domain Enforcement: Only users with @neu.edu.ph emails are permitted to create profiles.
     * - Admin Dominance: Users with 'Admin' status (verified via /roles_admin) have broad read/write 
     *   access across the system for management.
     * - Professor Restrictions: Professors can only create logs for themselves and only if their 
     *   account status is not 'blocked'.
     * - Structural Segregation: Administrative markers are kept in a separate collection to ensure 
     *   that role elevation cannot happen via simple profile updates.
     *
     * DENORMALIZATION FOR AUTHORIZATION:
     * - User IDs are enforced as document IDs in /user_profiles to allow O(1) ownership checks.
     * - Room logs contain the 'professorId' directly to allow the rules to verify the creator 
     *   without secondary lookups.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isNEUEmail() {
      return request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isNotBlocked(userId) {
      return get(/databases/$(database)/documents/user_profiles/$(userId)).data.isBlocked == false;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual user profile documents. Controls access to PII and roles.
     * @path /user_profiles/{userId}
     * @allow (get) If the user is the owner or an admin.
     * @deny (list) If the user is not an admin (listing all users is restricted).
     * @principle Ownership-based read; Admin-only collection listing.
     */
    match /user_profiles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && isNEUEmail() && request.resource.data.id == userId) || isAdmin();
      allow update: if (isExistingOwner(userId) && request.resource.data.id == resource.data.id) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Records of laboratory usage. Read access is strictly for audit/admin purposes.
     * @path /room_logs/{roomLogId}
     * @allow (create) If the user is a professor, owns the log, and is not blocked.
     * @deny (get/list) If the user is not an admin.
     * @principle Restricted write based on account status; Admin-only read access.
     */
    match /room_logs/{roomLogId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && isNotBlocked(request.auth.uid) && request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Marker collection for administrator UIDs.
     * @path /roles_admin/{userId}
     * @allow (all) Only if the requesting user is already an administrator.
     * @deny (all) For any non-admin user, including self-registration as admin.
     * @principle Structural segregation of roles for secure authorization.
     */
    match /roles_admin/{userId} {
      allow get, list, create, update, delete: if isAdmin();
    }
  }
}

// PROTOTYPING MODE: Data shapes are flexible. Relational integrity for 'id' and 'professorId' is enforced. 
// Standard content fields (names, timestamps, room numbers) are not type-validated to allow for rapid schema iteration.

/**
 * REASONING SUMMARY (Per IR):
 * 1. User Profiles: Uses document ID matching for zero-cost ownership checks.
 * 2. Room Logs: Admin-only read access via exists() check on roles_admin collection. 
 *    Professors check their own 'isBlocked' status via a single get() call during creation.
 * 3. Admin Roles: Uses 'Existence over Content' principle for global admin checks.
 */

/* 
  CRITICAL SYNTAX NOTE: All 'allow' conditions are on a single line 
  to comply with the generation framework's robustness requirements.
*/