
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roomLogs/{logId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.professorEmail == request.auth.token.email);
      allow create: if isSignedIn() && request.resource.data.professorEmail == request.auth.token.email;
      allow update: if isSignedIn() && (isAdmin() || resource.data.professorEmail == request.auth.token.email);
      allow delete: if isAdmin();
    }
  }
}
