
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalUser() {
      // Allows main domain and any institutional subdomains (e.g. student.neu.edu.ph)
      // We check for verified email domain match.
      return isSignedIn() && 
             request.auth.token.email.matches('.*@(.+\\.)?neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      return !exists(profilePath) || get(profilePath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isInstitutionalUser();
      // Allow authenticated institutional users to perform lookup and directory viewing
      allow list: if isInstitutionalUser() || isAdmin();
      allow create: if isInstitutionalUser() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin() || isInstitutionalUser();
      allow delete: if isAdmin();
    }

    match /room_logs/{logId} {
      // Allow institutional users and admins to view activity logs
      allow get, list: if isAdmin() || isInstitutionalUser();
      allow create: if isInstitutionalUser() && 
                       isNotBlocked() && 
                       request.resource.data.professorId == request.auth.uid;
      allow update, delete: if isAdmin() || isInstitutionalUser();
    }

    match /roles_admin/{userId} {
      // Allow the owner to check if they have an admin role
      allow get: if isOwner(userId) || isInstitutionalUser();
      allow read, write: if false;
    }
  }
}
