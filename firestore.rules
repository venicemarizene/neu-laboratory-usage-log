
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isActive() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email == resource.data.professorEmail);
      allow create: if isSignedIn() && isActive() && 
        request.resource.data.professorEmail == request.auth.token.email;
      allow update: if isAdmin() || (
        isSignedIn() && 
        isActive() && 
        request.auth.token.email == resource.data.professorEmail &&
        request.resource.data.professorEmail == resource.data.professorEmail
      );
      allow delete: if isAdmin();
    }
  }
}
