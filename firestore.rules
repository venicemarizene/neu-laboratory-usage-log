
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalUser() {
      // Robust check for main domain and institutional subdomains
      return isSignedIn() && 
             'email' in request.auth.token &&
             request.auth.token.email.matches('(?i).*@([^@]+\\.)?neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Use exists() to check for explicit admin role in roles_admin collection
      // Avoid using this function inside the roles_admin block itself to prevent recursion
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      // If profile doesn't exist, they are not blocked yet (initial creation)
      return !exists(profilePath) || get(profilePath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      // Owners and Admins can always read profiles. Institutional users can check existence.
      allow get: if isOwner(userId) || isAdmin() || isInstitutionalUser();
      // Admins and institutional users can list for management.
      allow list: if isInstitutionalUser() || isAdmin();
      // Users can create their own profile if they have an institutional email.
      allow create: if isInstitutionalUser() && isOwner(userId);
      // Admins can update any profile; users can update their own.
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /room_logs/{logId} {
      // Admins and institutional users can monitor activity logs.
      allow get, list: if isAdmin() || isInstitutionalUser();
      // Active institutional users can log their sessions.
      allow create: if isInstitutionalUser() && 
                       isNotBlocked() && 
                       request.resource.data.professorId == request.auth.uid;
      // Only admins can modify or remove historical logs.
      allow update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      // Owners can check their own status without triggering recursive isAdmin()
      allow get: if isOwner(userId) || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
      // Authorized institutional users can register as an admin marker for themselves.
      allow create, update: if isOwner(userId) && isInstitutionalUser();
      // Only existing admins can list or delete admin markers.
      allow list, delete: if isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  }
}
