rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalUser() {
      return isSignedIn() && 
             'email' in request.auth.token &&
             request.auth.token.email.matches('(?i).*@([^@]+\\.)?neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isNotBlocked() {
      let profilePath = /databases/$(database)/documents/user_profiles/$(request.auth.uid);
      return !exists(profilePath) || get(profilePath).data.isBlocked == false;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      // Access: Owners read/write own. Admins read all.
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Institutional users can initialize their own profile.
      allow create: if isInstitutionalUser() && isOwner(userId);
      
      // Update: Owner can update own. Admins full control.
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isBlocked'])) || isAdmin();
      
      allow delete: if isAdmin();
    }

    match /room_logs/{logId} {
      // Admins view all logs. Professors see nothing except creation.
      allow get, list: if isAdmin();
      
      // Creation: Active institutional users only.
      allow create: if isInstitutionalUser() && 
                       isNotBlocked() && 
                       request.resource.data.professorId == request.auth.uid;
                       
      allow update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, create, update, delete: if isAdmin();
    }
  }
}
