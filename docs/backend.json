
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user (Professor or Admin) in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["professor", "admin"] },
        "status": { "type": "string", "enum": ["active", "blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "status"]
    },
    "Room": {
      "title": "Room",
      "description": "Represents a computer laboratory room.",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId"]
    },
    "RoomLog": {
      "title": "RoomLog",
      "description": "Records of laboratory usage sessions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "professorEmail": { "type": "string", "format": "email" },
        "room": { "type": "string" },
        "timeIn": { "type": "string", "format": "date-time" },
        "timeOut": { "type": "string", "format": "date-time", "nullable": true },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["professorEmail", "room", "timeIn", "status"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and permissions."
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/backend/entities/Room" },
      "description": "Registered laboratory rooms."
    },
    "/roomLogs/{logId}": {
      "schema": { "$ref": "#/backend/entities/RoomLog" },
      "description": "Detailed usage logs for rooms."
    }
  }
}
