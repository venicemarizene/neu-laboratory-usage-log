
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user (Professor or Admin) in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Firebase UID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address."
        },
        "role": {
          "type": "string",
          "enum": ["professor", "admin"],
          "description": "User role."
        },
        "status": {
          "type": "string",
          "enum": ["active", "blocked"],
          "description": "Account status."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of account creation."
        }
      },
      "required": ["id", "email", "role", "status", "createdAt"]
    },
    "RoomLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RoomLog",
      "type": "object",
      "description": "Records laboratory usage.",
      "properties": {
        "id": {
          "type": "string"
        },
        "professorId": {
          "type": "string"
        },
        "professorName": {
          "type": "string"
        },
        "roomNumber": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string"
        }
      },
      "required": ["id", "professorId", "professorName", "roomNumber", "timestamp", "status"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user metadata. Admins can read/write all; users can read their own."
        }
      },
      {
        "path": "/room_logs/{logId}",
        "definition": {
          "entityName": "RoomLog",
          "schema": { "$ref": "#/backend/entities/RoomLog" },
          "description": "Records of laboratory entry. Admins can read all; Professors can create for themselves."
        }
      }
    ]
  }
}
