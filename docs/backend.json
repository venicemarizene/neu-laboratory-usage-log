
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile within the NEU Lab Log system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Professor", "Admin"] },
        "isBlocked": { "type": "boolean" },
        "qrString": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "isBlocked", "qrString"]
    },
    "RoomLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RoomLog",
      "type": "object",
      "description": "Records an instance of a laboratory room usage event.",
      "properties": {
        "id": { "type": "string" },
        "professorId": { "type": "string" },
        "roomNumber": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "professorId", "roomNumber", "timestamp", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "user_profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Stores individual user profiles."
    },
    "room_logs/{logId}": {
      "schema": "RoomLog",
      "description": "Records instances of laboratory room usage."
    },
    "roles_admin/{userId}": {
      "schema": "UserProfile",
      "description": "Administrative role marker."
    }
  }
}
